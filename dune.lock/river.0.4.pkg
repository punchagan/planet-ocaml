(version 0.4)

(build
 (all_platforms
  ((action
    (progn
     (when %{pkg-self:dev} (run dune subst))
     (run dune build -p %{pkg-self:name} -j %{jobs} @install))))))

(depends
 (all_platforms
  (ocaml dune syndic cohttp cohttp-lwt cohttp-lwt-unix ptime lwt lambdasoup)))

(source
 (fetch
  (url https://github.com/tarides/river/releases/download/0.4/river-0.4.tbz)
  (checksum
   sha256=c11a290101c8b80cf3c482bf11f5be2a9de97e8b92d5859e12034358792dec51)))
